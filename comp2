#include <math.h>
#include <string.h>

#include "vex.h"

using namespace vex;

brain Brain;

#define waitUntil(condition)                                                   \
  do {                                                                         \
    wait(5, msec);                                                             \
  } while (!(condition))

#define repeat(iterations)                                                     \
  for (int iterator = 0; iterator < iterations; iterator++)

optical Optical7 = optical(PORT7);
motor LeftDriveSmart = motor(PORT1, ratio18_1, false);
motor RightDriveSmart = motor(PORT2, ratio18_1, true);
drivetrain Drivetrain = drivetrain(LeftDriveSmart, RightDriveSmart, 319.19, 295, 40, mm, 1);
distance Distance6 = distance(PORT6);
inertial Inertial11 = inertial(PORT11);
motor RoboticArm3_mJ1 = motor(PORT3, ratio18_1, false);
motor RoboticArm3_mJ2 = motor(PORT4, ratio18_1, true);
motor RoboticArm3_mJ3 = motor(PORT5, ratio18_1, false);
motor RoboticArm3_mJ4 = motor(PORT8, ratio18_1, false);

void initializeRandomSeed(){
  int systemTime = Brain.Timer.systemHighResolution();
  double batteryCurrent = Brain.Battery.current();
  double batteryVoltage = Brain.Battery.voltage(voltageUnits::mV);
  int seed = int(batteryVoltage + batteryCurrent * 100) + systemTime;
  srand(seed);
}

void vexcodeInit() { initializeRandomSeed(); }
#pragma endregion VEXcode Generated Robot Configuration

competition Competition;

/*============================================================================*/
/*  TUNING CONSTANTS                                                          */
/*============================================================================*/

const double DRIVE_SPEED         = 40.0;
const double TURN_PCT            = 15.0;
const double WHEEL_CIRC_IN       = 319.19 / 25.4;
const double TURN_90_TARGET      = 85.0;

const int    ARM_RAISE_MS        = 1500;
const int    ARM_LOWER_MS        = 1500;   // full lower for pickup
const int    ARM_LOWER_SMALL_MS  = 400;    // small lower (~4 inches) for drop -- TUNE THIS
const double ARM_SPEED           = 25.0;
const int    CLAW_OPEN_MS        = 1000;
const int    CLAW_CLOSE_MS       = 1000;
const double CLAW_SPEED          = 30.0;

const int    ARM_DIR             = 1;
const int    CLAW_DIR            = -1;

/*============================================================================*/
/*  SCREEN HELPERS                                                            */
/*============================================================================*/

int screenLine = 1;

void lcdClear() {
  Brain.Screen.clearScreen();
  screenLine = 1;
}

void lcdPrint(const char* text) {
  Brain.Screen.setCursor(screenLine++, 1);
  Brain.Screen.print(text);
  if (screenLine > 12) screenLine = 1;
}

/*============================================================================*/
/*  DRIVE HELPERS                                                             */
/*============================================================================*/

void driveForwardInches(double inches) {
  LeftDriveSmart.resetPosition();
  double targetDeg = (inches / WHEEL_CIRC_IN) * 360.0;
  Drivetrain.setDriveVelocity(DRIVE_SPEED, percent);
  Drivetrain.drive(forward);
  while (fabs(LeftDriveSmart.position(degrees)) < targetDeg) {
    wait(20, msec);
  }
  Drivetrain.stop();
  wait(150, msec);
}

void driveReverseInches(double inches) {
  LeftDriveSmart.resetPosition();
  double targetDeg = (inches / WHEEL_CIRC_IN) * 360.0;
  Drivetrain.setDriveVelocity(DRIVE_SPEED, percent);
  Drivetrain.drive(reverse);
  while (fabs(LeftDriveSmart.position(degrees)) < targetDeg) {
    wait(20, msec);
  }
  Drivetrain.stop();
  wait(150, msec);
}

void turnLeft90() {
  Inertial11.resetRotation();
  LeftDriveSmart.spin(reverse, TURN_PCT, percent);
  RightDriveSmart.spin(forward, TURN_PCT, percent);
  while (fabs(Inertial11.rotation(degrees)) < TURN_90_TARGET) {
    wait(10, msec);
  }
  LeftDriveSmart.stop(brake);
  RightDriveSmart.stop(brake);
  wait(500, msec);
}

void turnLeftDeg(double target) {
  Inertial11.resetRotation();
  LeftDriveSmart.spin(reverse, TURN_PCT, percent);
  RightDriveSmart.spin(forward, TURN_PCT, percent);
  while (fabs(Inertial11.rotation(deg)) < target - 5.0) {
    wait(10, msec);
  }
  LeftDriveSmart.stop(brake);
  RightDriveSmart.stop(brake);
  wait(500, msec);
}

void turnRight90() {
  Inertial11.resetRotation();
  LeftDriveSmart.spin(forward, TURN_PCT, percent);
  RightDriveSmart.spin(reverse, TURN_PCT, percent);
  while (fabs(Inertial11.rotation(degrees)) < TURN_90_TARGET) {
    wait(10, msec);
  }
  LeftDriveSmart.stop(brake);
  RightDriveSmart.stop(brake);
  wait(500, msec);
}

/*============================================================================*/
/*  ARM & CLAW                                                                */
/*============================================================================*/

void armRaise() {
  directionType dir = (ARM_DIR > 0) ? forward : reverse;
  RoboticArm3_mJ2.spin(dir, ARM_SPEED, percent);
  wait(ARM_RAISE_MS, msec);
  RoboticArm3_mJ2.stop(hold);
}

// Full lower — used during pickup to reach the ground
void armLower() {
  directionType dir = (ARM_DIR > 0) ? reverse : forward;
  RoboticArm3_mJ2.spin(dir, ARM_SPEED, percent);
  wait(ARM_LOWER_MS, msec);
  RoboticArm3_mJ2.stop(hold);
}

// Small lower (~4 inches) — used during drop so rover is gently released
void armLowerSmall() {
  directionType dir = (ARM_DIR > 0) ? reverse : forward;
  RoboticArm3_mJ2.spin(dir, ARM_SPEED, percent);
  wait(ARM_LOWER_SMALL_MS, msec);
  RoboticArm3_mJ2.stop(hold);
}

void clawOpen() {
  directionType dir = (CLAW_DIR > 0) ? forward : reverse;
  RoboticArm3_mJ4.spin(dir, CLAW_SPEED, percent);
  wait(CLAW_OPEN_MS, msec);
  RoboticArm3_mJ4.stop();
}

void clawClose() {
  directionType dir = (CLAW_DIR > 0) ? reverse : forward;
  RoboticArm3_mJ4.spin(dir, CLAW_SPEED, percent);
  wait(CLAW_CLOSE_MS, msec);
}

/*============================================================================*/
/*  PICKUP & DROP                                                             */
/*============================================================================*/

void pickupRover() {
  lcdClear(); lcdPrint("Lowering arm...");
  armLower();            // full lower to reach ground
  wait(200, msec);

  lcdClear(); lcdPrint("Opening claw...");
  clawOpen();
  wait(300, msec);

  lcdClear(); lcdPrint("Closing claw...");
  clawClose();
  wait(300, msec);

  lcdClear(); lcdPrint("Raising arm...");
  armRaise();
  wait(200, msec);
}

void dropRover() {
  lcdClear(); lcdPrint("Stopping grip...");
  RoboticArm3_mJ4.stop();
  wait(200, msec);

  lcdClear(); lcdPrint("Lowering arm...");
  armLowerSmall();       // small lower (~4 inches) — gentle release
  wait(200, msec);

  lcdClear(); lcdPrint("Opening claw...");
  clawOpen();
  wait(300, msec);

  lcdClear(); lcdPrint("Raising arm...");
  armRaise();
  wait(200, msec);
}

/*============================================================================*/
/*  MAIN SEQUENCE                                                             */
/*============================================================================*/

void pre_auton() {
  vexcodeInit();
  lcdClear();
  lcdPrint("Lumena - Mini Test");
  lcdPrint("Calibrating inertial...");
  Inertial11.calibrate();
  waitUntil(!Inertial11.isCalibrating());
  lcdPrint("Inertial OK.");

  Drivetrain.setStopping(brake);
  armRaise();
  clawOpen();

  lcdClear();
  lcdPrint("Ready.");
}

void autonomous() {
  lcdClear();

  // 1. Drive forward 63 inches
  lcdPrint("Step 1: Forward 63in");
  driveForwardInches(63);

  // 2. Turn right 90 degrees
  lcdPrint("Step 2: Turn right 90");
  turnRight90();

  // 3. Drive forward 7 inches to rover
  lcdPrint("Step 3: Forward 7in");
  driveForwardInches(6);

  // 4. Pick up rover
  lcdPrint("Step 4: Pickup rover");
  pickupRover();

  // 5. Reverse 7 inches
  lcdPrint("Step 5: Reverse 7in");
  driveReverseInches(6);

  // 6. Turn left 90 degrees
  lcdPrint("Step 6: Turn left 90");
  turnLeft90();

  // 7. Reverse 40 inches
  lcdPrint("Step 7: Reverse 40in");
  driveReverseInches(40);

  // 8. Turn left 50 degrees
  lcdPrint("Step 8: Turn left 50");
  turnLeftDeg(165);

  // 9. Forward 40 inches
  lcdPrint("Step 9: Forward 40in");
  driveForwardInches(30);

  // 10. Drop rover
  lcdPrint("Step 10: Drop rover");
  dropRover();

  lcdClear();
  lcdPrint("=== DONE ===");
}

void usercontrol() {
  while (true) { wait(20, msec); }
}

int main() {
  pre_auton();
  autonomous();
  while (true) { wait(100, msec); }
  return 0;
}
