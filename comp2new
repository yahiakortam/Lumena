/*  TUNING CONSTANTS                                                          */
/*============================================================================*/

const double DRIVE_SPEED         = 20.0;
const double TURN_PCT            = 10.0;
const double WHEEL_CIRC_IN       = 319.19 / 25.4;
const double TURN_90_TARGET      = 85.0;

const int    ARM_RAISE_MS        = 1500;
const int    ARM_LOWER_MS        = 1500;
const int    ARM_LOWER_SMALL_MS  = 400;
const double ARM_SPEED           = 25.0;
const int    CLAW_OPEN_MS        = 1000;
const int    CLAW_CLOSE_MS       = 1000;
const double CLAW_SPEED          = 30.0;

const int    ARM_DIR             = 1;
const int    CLAW_DIR            = -1;

// Mineral detection thresholds -- TUNE IF NEEDED
const double BRIGHT_MIN          = 10.0;   // ignore sensor if too dark
const double RED_HUE_MAX         = 20.0;   // red wraps near 0
const double RED_HUE_WRAP        = 340.0;  // and near 360
const double YELLOW_HUE_MIN      = 21.0;
const double YELLOW_HUE_MAX      = 75.0;
const double GREEN_HUE_MIN       = 76.0;
const double GREEN_HUE_MAX       = 160.0;
const int    MINERAL_COOLDOWN_MS = 1500;   // ms before re-triggering same mineral

/*============================================================================*/
/*  MINERAL DETECTION — BACKGROUND TASK                                       */
/*  Runs the entire match. Checks optical sensor every 50ms.                  */
/*  Writes to bottom rows of screen only — never stops movement.              */
/*============================================================================*/

int  g_mineralsFound    = 0;
bool g_mineralActive    = false;  // true while tape is still under sensor
const char* g_lastColor = "---";
int  g_lastMineralTime  = -99999;

int mineralMonitorTask() {
  Optical7.setLight(ledState::on);
  Optical7.setLightPower(100, pct);

  while (true) {
    int now = (int)(Brain.Timer.value() * 1000);

    if (Optical7.brightness() >= BRIGHT_MIN &&
        (now - g_lastMineralTime) >= MINERAL_COOLDOWN_MS) {

      double hue = Optical7.hue();
      const char* detected = nullptr;

      if (hue <= RED_HUE_MAX || hue >= RED_HUE_WRAP) {
        detected = "RED";
      } else if (hue >= YELLOW_HUE_MIN && hue <= YELLOW_HUE_MAX) {
        detected = "YELLOW";
      } else if (hue >= GREEN_HUE_MIN && hue <= GREEN_HUE_MAX) {
        detected = "GREEN";
      }

      if (detected != nullptr) {
        g_mineralsFound++;
        g_lastColor      = detected;
        g_lastMineralTime = now;

        // Write to bottom 3 rows — doesn't clear the whole screen
        Brain.Screen.setCursor(10, 1);
        Brain.Screen.print("!! MINERAL: %-6s !!", detected);
        Brain.Screen.setCursor(11, 1);
        Brain.Screen.print("Total minerals: %d  ", g_mineralsFound);
      }
    }

    wait(50, msec);
  }
  return 0;
}

