void pickupRover() {
  lcdClear(); lcdPrint("Lowering arm...");
  armLower();
  wait(200, msec);

  lcdClear(); lcdPrint("Opening claw...");
  clawOpen();
  wait(300, msec);

  lcdClear(); lcdPrint("Closing claw...");
  clawClose();
  wait(300, msec);

  lcdClear(); lcdPrint("Raising arm...");
  armRaise();
  wait(200, msec);
}

void dropRover() {
  lcdClear(); lcdPrint("Stopping grip...");
  RoboticArm3_mJ4.stop();
  wait(200, msec);

  lcdClear(); lcdPrint("Lowering arm...");
  armLowerSmall();
  wait(200, msec);

  lcdClear(); lcdPrint("Opening claw...");
  clawOpen();
  wait(300, msec);

  lcdClear(); lcdPrint("Raising arm...");
  armRaise();
  wait(200, msec);
}

