void autonomous() {
  // Start mineral monitor running in background
  task mineralTask(mineralMonitorTask);

  lcdClear();

  // --- Rover 1 ---
  lcdPrint("Step 1: Forward 32in");
  driveForwardInches(32);

  lcdPrint("Step 2: Turn right 30");
  turnRightDeg(30);

  lcdPrint("Step 3: Forward 7in");
  driveForwardInches(7);

  lcdPrint("Step 4: Pickup rover");
  pickupRover();

  driveForwardInches(3);
  turnRightDeg(60);
  turnRightDeg(85);
  driveForwardInches(30);

  lcdPrint("Drop rover 1");
  dropRover();

  // --- Rover 2 ---
  lcdPrint("Turn left 90");
  turnLeft90();

  lcdPrint("Forward 106in");
  driveForwardInches(106);

  lcdPrint("Turn right 90");
  turnRight90();

  lcdPrint("Forward 33in");
  driveForwardInches(33);

  lcdPrint("Turn left 90");
  turnLeft90();

  lcdPrint("Forward 3in");
  driveForwardInches(3);

  lcdPrint("Pickup rover 2");
  pickupRover();

  lcdClear();
  lcdPrint("=== DONE ===");
}

